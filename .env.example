# PostgreSQL — local : docker compose up -d puis URL ci-dessous.
# Production (Vercel) : base Neon / Vercel Postgres (URL pooled recommandée).
DATABASE_URL="postgresql://automaroc:automaroc@localhost:5432/automaroc?schema=public"

AUTH_SECRET="changez-moi-32-caracteres-minimum-secret-jwt"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Photos catalogue (génération) : https://www.pexels.com/api/ — gratuit avec quota
PEXELS_ACCESS_KEY=
# (synonyme accepté par le script) PEXELS_API_KEY=

# Assistant sur chaque fiche véhicule : sans clé, réponses « mode fiche » ; avec clé, OpenAI.
# Collez votre clé après le = (sans guillemets en général). Redémarrez le serveur après modification.
# Exemple : OPENAI_API_KEY=sk-proj-xxxxxxxx
OPENAI_API_KEY=
# Synonyme accepté si vous préférez ce nom :
# OPENAI_KEY=
# Optionnel, défaut gpt-4o-mini
OPENAI_MODEL=

# Import avis Google Maps (script reviews:google) — Places API (New) activée sur la clé
GOOGLE_MAPS_API_KEY=
# Synonyme accepté :
# GOOGLE_PLACES_API_KEY=

# Après changement de schéma : npm run db:push && npm run db:seed
# Regénérer le JSON catalogue (Pexels + Wikipédia + avis démo) : npm run catalog:generate
